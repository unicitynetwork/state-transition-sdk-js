{
  "name": "@unicitylabs/state-transition-sdk",
  "version": "1.4.7",
  "description": "Generic State Transition Flow engine for value-carrier agents",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "browser": "./dist/unicity-sdk.min.js",
  "unpkg": "./dist/unicity-sdk.min.js",
  "jsdelivr": "./dist/unicity-sdk.min.js",
  "type": "module",
  "scripts": {
    "prebuild": "rm -rf lib dist",
    "build": "npm run build:node && npm run build:browser",
    "build:node": "tsc",
    "build:browser": "webpack",
    "build:check": "tsc --noEmit",
    "lint": "eslint \"src/**/*\"",
    "lint:fix": "eslint \"src/**/*\" --fix",
    "test": "jest --testPathPattern=tests --testPathIgnorePatterns=tests/e2e",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:e2e": "jest --testPathPattern=tests/e2e",
    "test:browser": "jest --config jest.browser.config.js",
    "test:ci": "DEBUG=testcontainers:containers jest --testPathPattern=tests --testPathIgnorePatterns=tests/e2e --ci --reporters=default",
    "test:single": "jest",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/unicitynetwork/state-transition-sdk.git"
  },
  "files": [
    "lib/**/*",
    "dist/**/*",
    "LICENSE",
    "README.md"
  ],
  "author": "cryptohog",
  "license": "ISC",
  "homepage": "https://unicitynetwork.github.io/state-transition-sdk/",
  "dependencies": {
    "@unicitylabs/commons": "2.4.0-rc.5328eac",
    "@unicitylabs/prefix-hash-tree": "1.2.13-rc.43a27ce"
  },
  "devDependencies": {
    "@babel/preset-env": "7.27.2",
    "@babel/preset-typescript": "7.27.1",
    "@eslint/js": "9.27.0",
    "@types/jest": "29.5.14",
    "babel-jest": "29.7.0",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.12.1",
    "eslint": "9.27.0",
    "eslint-config-prettier": "10.1.5",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-prettier": "5.4.0",
    "globals": "16.2.0",
    "http-server": "^14.1.1",
    "jest": "29.7.0",
    "jest-puppeteer": "^11.0.0",
    "process": "^0.11.10",
    "puppeteer": "^24.10.1",
    "stream-browserify": "^3.0.0",
    "testcontainers": "11.0.0",
    "ts-loader": "^9.5.2",
    "typescript": "5.8.3",
    "typescript-eslint": "8.33.0",
    "util": "^0.12.5",
    "webpack": "^5.99.9",
    "webpack-cli": "^6.0.1"
  },
  "overrides": {
    "@unicitylabs/commons": "2.4.0-rc.5328eac"
  }
}
