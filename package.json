{
  "name": "@unicitylabs/state-transition-sdk",
  "version": "2.0.1",
  "description": "Generic State Transition Flow engine for value-carrier agents",
  "type": "module",
  "exports": {
    "./lib/*.js": "./lib/*.js",
    "./lib/*": "./lib/*.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "build:check": "tsc --noEmit",
    "lint": "eslint \"src/**/*\" \"tests/**/*\"",
    "lint:fix": "eslint \"src/**/*\" \"tests/**/*\" --fix",
    "test": "npm run-script test:unit",
    "test:unit": "jest --testPathPatterns=tests/unit --testPathPatterns=tests/functional",
    "test:e2e": "jest --testPathPatterns=tests/e2e",
    "test:examples": "jest --testPathPatterns=tests/examples",
    "test:ci": "jest --testPathPatterns=tests --testPathIgnorePatterns=tests/e2e --testPathIgnorePatterns=tests/examples --ci --reporters=default"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/unicitynetwork/state-transition-sdk-js.git"
  },
  "files": [
    "lib/**/*",
    "LICENSE",
    "README.md"
  ],
  "author": "cryptohog",
  "license": "ISC",
  "homepage": "https://unicitynetwork.github.io/state-transition-sdk-js/",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@noble/curves": "2.2.0",
    "@noble/hashes": "2.2.0",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@babel/preset-env": "8.0.2",
    "@babel/preset-typescript": "8.0.1",
    "@eslint/js": "9.39.5",
    "@types/jest": "30.0.0",
    "@types/node": "22.13.14",
    "babel-jest": "30.4.1",
    "eslint": "9.39.5",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.6",
    "globals": "17.7.0",
    "jest": "30.4.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.65.0"
  }
}
